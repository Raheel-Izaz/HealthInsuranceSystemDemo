@model IEnumerable<Company>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center pb-3 mb-4 border-bottom">
        <div>
            <h1 class="h2 text-dark mb-1">Company Management Dashboard</h1>
            <p class="text-muted mb-0">System Domain Operations • Role: Super Admin / Account Manager</p>
        </div>
        <div>
            <a asp-controller="Policy" asp-action="Create" class="btn btn-success px-4 fw-bold shadow-sm">
                + Issue New Policy Contract
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-3 mb-5">
        <div class="card-body p-4 bg-light rounded-3 border">
            <h5 class="card-title fw-bold text-dark mb-2">Bulk Ingest Corporate Accounts</h5>
            <p class="text-muted small mb-4">
                Select your pre-formatted spreadsheet (`.xlsx` or `.xls`) to process and sync corporate client rosters directly into the database.
            </p>
            
            <form asp-action="UploadExcel" method="post" enctype="multipart/form-data" class="row g-3 align-items-center">
                @Html.AntiForgeryToken()
                
                <div class="col-md-8 col-lg-6">
                    <div class="input-group">
                        <input type="file" name="file" class="form-control" accept=".xlsx, .xls" required />
                    </div>
                </div>
                <div class="col-md-4 col-lg-3">
                    <button type="submit" class="btn btn-primary w-100 fw-bold shadow-sm">
                        <i class="bi bi-cloud-arrow-up-fill me-2"></i> Execute Batch Ingest
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm border">
        <div class="card-header bg-white py-3 border-bottom-0">
            <h5 class="mb-0 fw-bold text-secondary">Active Enrolled Corporations</h5>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th scope="col" style="width: 15%;">Database ID</th>
                        <th scope="col" style="width: 45%;">Registered Corporate Profile Name</th>
                        <th scope="col" style="width: 25%;">Ingestion Provenance / Origin</th>
                        <th scope="col" style="width: 15%;" class="text-end">Ledger Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                <i class="bi bi-folder-x display-4 d-block mb-3 text-secondary"></i>
                                No corporate registry entities detected. Utilize the bulk upload interface above to seed operational data.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var company in Model)
                        {
                            <tr>
                                <td class="fw-bold text-secondary">#@company.Id</td>
                                <td class="fw-bold text-dark text-uppercase">@company.Name</td>
                                <td>
                                    <span class="badge bg-secondary-subtle text-secondary px-3 py-2 rounded-pill border">
                                        <i class="bi bi-cpu me-1"></i> @company.CreatedBy
                                    </span>
                                </td>
                                <td class="text-end">
                                    @if (company.Policies != null && company.Policies.Any())
                                    {
                                        // Grab the most recently issued policy contract ID
                                        var activePolicyId = company.Policies.Last().Id;
                                        <a asp-controller="Policy" asp-action="Details" asp-route-id="@activePolicyId" class="btn btn-sm btn-outline-primary fw-bold px-3 rounded-pill shadow-sm">
                                            <i class="bi bi-receipt me-1"></i> View Ledger
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted small italic">No Policy Found</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>